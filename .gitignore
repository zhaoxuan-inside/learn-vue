.env.local
.env.*.local

# Vite 临时文件
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 测试覆盖率报告目录
coverage
*.tsbuildinfo

# 编辑器或 IDE 的配置文件 (根据团队需要决定是否部分提交)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS 生成的文件
.DS_Store
Thumbs.db